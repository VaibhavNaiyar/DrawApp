# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/drawapp"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Single secret for NextAuth, http-backend, ws-backend, draw-ws-backend.
# Generate one: openssl rand -base64 32
AUTH_SECRET="your-strong-secret-here"

# ─── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_HTTP_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:8080"
NEXT_PUBLIC_DRAW_WS_URL="ws://localhost:8081"

# ─── Service Ports ─────────────────────────────────────────────────────────────
DRAW_WS_PORT=8081

# ─── Docker Compose ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=drawapp_dev
